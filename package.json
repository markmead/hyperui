{
  "name": "hyperui",
  "type": "module",
  "scripts": {
    "dev": "wrangler types && astro dev",
    "build": "wrangler types && astro build",
    "check": "astro check",
    "test": "playwright test",
    "lint": "eslint .",
    "format": "prettier --write . --ignore-path .prettierignore",
    "css:blog": "npx @tailwindcss/cli -i ./src/styles/blog.css -o ./public/blog.css -m",
    "css:component": "npx @tailwindcss/cli -i ./src/styles/component.css -o ./public/component.css -m",
    "generate:dark-variants": "node scripts/generate-dark-variants.js",
    "generate:git-metadata": "node scripts/generate-git-metadata.js"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/cloudflare": "^13.6.1",
    "@astrojs/mdx": "5.0.4",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "3.7.2",
    "@lucide/astro": "^1.17.0",
    "astro": "6.3.1",
    "wrangler": "^4.98.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/cli": "^4.3.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.1",
    "eslint-plugin-astro": "^1.7.0",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.4",
    "rehype-external-links": "^3.0.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1"
  },
  "overrides": {
    "vite": "^7"
  }
}
