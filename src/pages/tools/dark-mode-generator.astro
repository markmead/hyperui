---
import {
  SEO_TITLE_DARK_MODE_GENERATOR,
  SEO_DESCRIPTION_DARK_MODE_GENERATOR,
} from '../../constants/seo'

import BaseLayout from '../../layouts/BaseLayout.astro'
import DarkModeGenerator from '../../components/DarkModeGenerator.astro'
---

<BaseLayout title={SEO_TITLE_DARK_MODE_GENERATOR} description={SEO_DESCRIPTION_DARK_MODE_GENERATOR}>
  <main id="main-content" class="mx-auto max-w-7xl px-4 py-8">
    <div class="mb-8">
      <h1 class="text-3xl font-medium text-gray-900">Dark Mode Generator</h1>

      <p class="mt-2 text-gray-600">
        Paste Tailwind CSS HTML below and get dark mode variants added automatically. Configure
        rules to control which elements and colors are transformed.
      </p>
    </div>

    <DarkModeGenerator />
  </main>
</BaseLayout>
