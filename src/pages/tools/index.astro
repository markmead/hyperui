---
import { SEO_TITLE_TOOLS, SEO_DESCRIPTION_TOOLS } from '../../constants/seo'

import BaseLayout from '../../layouts/BaseLayout.astro'
import BaseHero from '../../components/BaseHero.astro'
---

<BaseLayout title={SEO_TITLE_TOOLS} description={SEO_DESCRIPTION_TOOLS}>
  <BaseHero
    title="Tools"
    description="Browser-based Tailwind CSS tools — dark mode generation, contrast checking, typography mapping, theme building, and more. Free, no install, no signup."
  />

  <main id="main-content" class="mx-auto max-w-7xl px-4 py-8">
    <ul class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
      <li>
        <a
          href="/tools/dark-mode-generator"
          class="group flex h-full flex-col rounded-lg border border-gray-200 bg-white p-6 transition-colors hover:border-gray-300 hover:bg-gray-50"
        >
          <h2 class="text-lg font-medium text-gray-900 group-hover:text-gray-700">
            Dark Mode Generator
          </h2>

          <p class="mt-2 text-sm text-gray-600">
            Paste any Tailwind CSS HTML and generate dark mode variants automatically. Configure
            rules to control which elements and colors are transformed.
          </p>
        </a>
      </li>

      <li>
        <div class="flex h-full flex-col rounded-lg border border-gray-200 bg-white p-6">
          <div class="mb-2 flex items-start justify-between gap-4">
            <h2 class="text-lg font-medium text-gray-900">Contrast Checker</h2>
            <span
              class="shrink-0 rounded-full bg-gray-100 px-2.5 py-0.5 text-xs font-medium text-gray-500"
              >Coming soon</span
            >
          </div>
          <p class="text-sm text-gray-600">
            Test any pair of Tailwind colors against WCAG AA and AAA contrast requirements to catch
            accessibility issues before they ship.
          </p>
        </div>
      </li>

      <li>
        <div class="flex h-full flex-col rounded-lg border border-gray-200 bg-white p-6">
          <div class="mb-2 flex items-start justify-between gap-4">
            <h2 class="text-lg font-medium text-gray-900">Typography Mapper</h2>
            <span
              class="shrink-0 rounded-full bg-gray-100 px-2.5 py-0.5 text-xs font-medium text-gray-500"
              >Coming soon</span
            >
          </div>
          <p class="text-sm text-gray-600">
            Enter px values from a design handoff and get the exact Tailwind class or the nearest
            tokens either side with an arbitrary value fallback.
          </p>
        </div>
      </li>

      <li>
        <div class="flex h-full flex-col rounded-lg border border-gray-200 bg-white p-6">
          <div class="mb-2 flex items-start justify-between gap-4">
            <h2 class="text-lg font-medium text-gray-900">Config Builder</h2>
            <span
              class="shrink-0 rounded-full bg-gray-100 px-2.5 py-0.5 text-xs font-medium text-gray-500"
              >Coming soon</span
            >
          </div>
          <p class="text-sm text-gray-600">
            Build your Tailwind v4 theme through a GUI — define color tokens, typography scales, and
            spacing — then copy the CSS variable block straight into your stylesheet.
          </p>
        </div>
      </li>
    </ul>
  </main>
</BaseLayout>
