---
import { SEO_TITLE_TOOLS, SEO_DESCRIPTION_TOOLS } from '../../constants/seo'

import BaseLayout from '../../layouts/BaseLayout.astro'
import BaseHero from '../../components/BaseHero.astro'
import ToolCard from '../../components/ToolCard.astro'

import type { Status } from '../../utils/status'

import tools from '../../data/tools.json'
---

<BaseLayout title={SEO_TITLE_TOOLS} description={SEO_DESCRIPTION_TOOLS}>
  <BaseHero
    title="Tools"
    description="Browser-based Tailwind CSS tools — dark mode generation, contrast checking, typography mapping, theme building, and more. Free, no install, no signup."
  />

  <main id="main-content" class="mx-auto max-w-7xl px-4 py-8">
    <ul class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        tools.map((tool) => (
          <li>
            <ToolCard
              href={tool.href}
              title={tool.title}
              status={tool.status as Status}
              description={tool.description}
            />
          </li>
        ))
      }
    </ul>
  </main>
</BaseLayout>
