---
import { SEO_TITLE_TYPOGRAPHY_MAPPER, SEO_DESCRIPTION_TYPOGRAPHY_MAPPER } from '../../constants/seo'

import BaseLayout from '../../layouts/BaseLayout.astro'
import BaseHero from '../../components/BaseHero.astro'
import TypographyMapper from '../../components/TypographyMapper.astro'
import StatusBadge from '../../components/StatusBadge.astro'
---

<BaseLayout title={SEO_TITLE_TYPOGRAPHY_MAPPER} description={SEO_DESCRIPTION_TYPOGRAPHY_MAPPER}>
  <BaseHero
    title="Typography Mapper"
    description="Enter font size and line height in pixels from a design handoff and get the exact Tailwind CSS class or the nearest tokens with an arbitrary value fallback."
    backHref="/tools"
    backLabel="Back to tools"
  >
    <StatusBadge slot="badge" status="beta" class="mb-4" />
  </BaseHero>

  <main id="main-content" class="mx-auto max-w-7xl px-4 py-8">
    <TypographyMapper />
  </main>
</BaseLayout>
