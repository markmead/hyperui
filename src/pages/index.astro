---
import { getCollection } from 'astro:content'

import { SEO_DESCRIPTION_SITE, SEO_TITLE_SITE } from '../consts'

import BaseLayout from '../layouts/BaseLayout.astro'
import CollectionFeature from '../components/CollectionFeature.astro'
import PageHero from '../components/PageHero.astro'

const [application, marketing, neobrutalism] = (
  await Promise.all([
    getCollection('application'),
    getCollection('marketing'),
    getCollection('neobrutalism'),
  ])
)
  .map((collection) => collection.slice(0, 6))
  .map((collection) =>
    collection.map(({ data }) => data).sort((a, b) => a.title.localeCompare(b.title)),
  )
---

<BaseLayout description={SEO_DESCRIPTION_SITE} title={SEO_TITLE_SITE}>
  <PageHero />

  <main
    id="main-content"
    class="mx-auto max-w-7xl divide-y divide-gray-200 border-t border-gray-200 px-4"
  >
    <CollectionFeature
      title="Application Components"
      description="Components for building application user interfaces"
      slug="application"
      button="View all application components"
      components={application}
    />

    <CollectionFeature
      title="Marketing Components"
      description="Components for building marketing websites and landing pages"
      slug="marketing"
      button="View all marketing components"
      components={marketing}
    />

    <CollectionFeature
      title="Neobrutalism Components"
      description="Components for building neobrutalist designs"
      slug="neobrutalism"
      button="View all neobrutalism components"
      components={neobrutalism}
    />
  </main>
</BaseLayout>
