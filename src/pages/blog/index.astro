---
import { getCollection } from 'astro:content'

import { SEO_TITLE_BLOG, SEO_DESCRIPTION_BLOG } from '../../consts'

import BaseLayout from '../../layouts/BaseLayout.astro'
import BaseHero from '../../components/BaseHero.astro'
import BlogCard from '../../components/BlogCard.astro'

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.updatedDate.valueOf() - a.data.updatedDate.valueOf(),
)

const blogListSchema = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'HyperUI Blog',
  description: SEO_DESCRIPTION_BLOG,
  url: new URL('/blog', Astro.site),
  blogPost: posts.map((post) => ({
    '@type': 'BlogPosting',
    headline: post.data.title,
    description: post.data.description,
    datePublished: post.data.pubDate.toISOString(),
    dateModified: post.data.updatedDate.toISOString(),
    url: new URL(`/blog/${post.data.slug}`, Astro.site),
  })),
}
---

<BaseLayout title={SEO_TITLE_BLOG} description={SEO_DESCRIPTION_BLOG}>
  <script
    type="application/ld+json"
    slot="head"
    is:inline
    set:html={JSON.stringify(blogListSchema)}
  />

  <BaseHero
    title="Tailwind CSS Blog"
    description="Tips, tricks and real-world solutions for working with Tailwind CSS"
  />

  <main id="main-content" class="mx-auto max-w-7xl divide-y divide-gray-200 px-4">
    {posts.map((post) => <BlogCard post={post} />)}
  </main>
</BaseLayout>
