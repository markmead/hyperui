---
import { ArrowLeft } from '@lucide/astro'

import ErrorLayout from '../layouts/ErrorLayout.astro'
---

<ErrorLayout title="404 - Page Not Found" description="Page not found">
  <main id="main-content" class="mx-auto max-w-3xl space-y-6 text-center">
    <h1 class="text-5xl font-medium text-gray-900">404 - Page Not Found</h1>

    <p class="text-gray-600">Sorry, the page you are looking for does not exist.</p>

    <a
      href="/"
      class="inline-flex items-center gap-2 text-gray-700 transition-colors hover:text-gray-900"
    >
      <ArrowLeft class="size-5" />

      <span>Go back home</span>
    </a>
  </main>
</ErrorLayout>
