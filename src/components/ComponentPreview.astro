---
interface Props {
  src: string
  title: string
  dark?: boolean
  index?: number
  wrapper?: string
  body?: string
  stylesheet?: string
}

const {
  src,
  title,
  dark = false,
  index = 1,
  wrapper = '',
  body = '',
  stylesheet = '/component.css',
} = Astro.props
---

<component-preview
  data-src={src}
  data-body={body}
  data-dark={dark ? 'true' : 'false'}
  data-stylesheet={stylesheet}
  class="block"
  aria-busy="true"
>
  <div
    data-loading
    class="flex items-center justify-center gap-2 border-b border-gray-200 bg-white px-4 py-3 text-sm text-gray-600"
  >
    <span
      class="size-4 animate-spin rounded-full border-2 border-gray-300 border-t-gray-700"
      aria-hidden="true"></span>
    <span>Loading preview...</span>
  </div>

  <iframe
    data-preview="true"
    {title}
    sandbox="allow-scripts"
    class:list={[
      wrapper,
      dark ? 'bg-gray-900' : 'bg-white',
      'mx-auto w-full ring ring-gray-200 transition-[max-width] duration-300 data-[preview=false]:hidden data-[preview=true]:block',
    ]}
    style="max-width: 100%;"
    loading={index === 1 && !dark ? 'eager' : 'lazy'}></iframe>

  <div
    data-preview="true"
    class="prose prose-pre:m-0 prose-pre:rounded-none max-h-150 max-w-none overflow-auto data-[preview=true]:hidden"
  >
    <pre data-html></pre>
  </div>
</component-preview>

<script>
  const PREVIEW_MESSAGE_TYPE = 'hyperui:preview-direction'
  const COMPONENT_SCRIPT_PATH = '/component.js'

  class ComponentPreview extends HTMLElement {
    private static componentCssTextPromiseByPath = new Map<string, Promise<string | null>>()
    private static componentJsTextPromise: Promise<string | null> | null = null

    private contentHtml: string | null = null
    private contentSrc: string | null = null
    private rawSourceHtml: string | null = null
    private contentBodyClass: string = ''
    private componentStylesheetPath: string = ''
    private isDarkPreview: boolean = false

    private iframeEl: HTMLIFrameElement | null = null
    private previewEl: HTMLPreElement | null = null
    private loadingEl: HTMLElement | null = null
    private previewDirection: 'ltr' | 'rtl' = 'ltr'

    private breakpointHandler: EventListener | null = null
    private copyHandler: EventListener | null = null
    private directionHandler: EventListener | null = null
    private viewHandler: EventListener | null = null
    private iframeLoadHandler: (() => void) | null = null

    connectedCallback() {
      this.contentSrc = this.dataset.src || null
      this.contentBodyClass = this.dataset.body || ''
      this.componentStylesheetPath = this.dataset.stylesheet || ''
      this.isDarkPreview = this.dataset.dark === 'true'

      if (!this.contentSrc) {
        return
      }

      this.iframeEl = this.querySelector('iframe')
      this.previewEl = this.querySelector('[data-html]')
      this.loadingEl = this.querySelector('[data-loading]')

      if (!this.iframeEl || !this.previewEl) {
        return
      }

      this.loadContent()
      this.setupEventListeners()

      this.iframeLoadHandler = () => {
        this.postDirectionToIframe()
      }

      this.iframeEl.addEventListener('load', this.iframeLoadHandler)
    }

    disconnectedCallback() {
      if (this.contentSrc) {
        this.removeDocumentListener(
          this.buildEventName('breakpoint:change'),
          this.breakpointHandler,
        )
        this.removeDocumentListener(this.buildEventName('preview:copy'), this.copyHandler)
        this.removeDocumentListener(this.buildEventName('preview:direction'), this.directionHandler)
        this.removeDocumentListener(this.buildEventName('preview:view'), this.viewHandler)
      }

      this.breakpointHandler = null
      this.copyHandler = null
      this.directionHandler = null
      this.viewHandler = null

      if (this.iframeEl && this.iframeLoadHandler) {
        this.iframeEl.removeEventListener('load', this.iframeLoadHandler)
        this.iframeLoadHandler = null
      }

      this.loadingEl = null
    }

    private setupEventListeners() {
      this.breakpointHandler = (event) => {
        const breakpointEvent = event as CustomEvent<{ width: string }>
        const newWidth = breakpointEvent.detail.width

        if (this.iframeEl) {
          this.iframeEl.style.maxWidth = newWidth
        }
      }

      this.copyHandler = () => {
        void this.copyPreviewContent()
      }

      this.directionHandler = (event) => {
        const directionEvent = event as CustomEvent<{ ltr: boolean }>
        const isLeftToRight = directionEvent.detail.ltr

        this.previewDirection = isLeftToRight ? 'ltr' : 'rtl'

        this.postDirectionToIframe()
      }

      this.viewHandler = (event) => {
        const viewEvent = event as CustomEvent<{ previewing: boolean }>
        const isPreviewing = viewEvent.detail.previewing

        const previewEls = this.querySelectorAll('[data-preview]')

        void this.syncPreviewCodeView()

        previewEls.forEach((previewEl) => {
          previewEl.setAttribute('data-preview', isPreviewing ? 'true' : 'false')
        })
      }

      if (this.contentSrc) {
        this.addDocumentListener(this.buildEventName('breakpoint:change'), this.breakpointHandler)
        this.addDocumentListener(this.buildEventName('preview:copy'), this.copyHandler)
        this.addDocumentListener(this.buildEventName('preview:direction'), this.directionHandler)
        this.addDocumentListener(this.buildEventName('preview:view'), this.viewHandler)
      }
    }

    private buildEventName(eventPrefix: string): string {
      return `${eventPrefix}:${this.contentSrc}`
    }

    private addDocumentListener(eventName: string, handler: EventListener | null) {
      if (!handler) {
        return
      }

      globalThis.document.addEventListener(eventName, handler)
    }

    private removeDocumentListener(eventName: string, handler: EventListener | null) {
      if (!handler) {
        return
      }

      globalThis.document.removeEventListener(eventName, handler)
    }

    private async copyPreviewContent() {
      try {
        const contentHtml = await this.getContent()

        if (contentHtml) {
          await navigator.clipboard.writeText(contentHtml)
        }
      } catch {
        // We do nothing
      }
    }

    private async syncPreviewCodeView() {
      const contentHtml = await this.getContent()

      if (contentHtml && this.previewEl) {
        this.previewEl.textContent = contentHtml
      }
    }

    private async loadContent() {
      if (!this.contentSrc || !this.iframeEl) {
        this.setLoadingState(false)
        return
      }

      try {
        const [componentCssText, componentJsText] = await Promise.all([
          this.loadComponentStylesheet(),
          this.loadComponentScript(),
        ])

        const sourceResponse = await fetch(this.contentSrc, { credentials: 'same-origin' })

        if (!sourceResponse.ok) {
          this.setLoadingState(false)
          return
        }

        const sourceDocumentHtml = await sourceResponse.text()

        this.rawSourceHtml = sourceDocumentHtml
        this.contentHtml = this.extractBodyContent(sourceDocumentHtml)

        this.iframeEl.srcdoc = this.buildPreviewDocument(
          sourceDocumentHtml,
          componentCssText,
          componentJsText,
        )
      } catch {
        // We do nothing
      } finally {
        this.setLoadingState(false)
      }
    }

    private setLoadingState(isLoading: boolean) {
      this.setAttribute('aria-busy', isLoading ? 'true' : 'false')

      if (this.loadingEl) {
        this.loadingEl.classList.toggle('hidden', !isLoading)
      }
    }

    private async loadComponentStylesheet(): Promise<string | null> {
      const stylesheetPath = this.componentStylesheetPath

      if (!stylesheetPath) {
        return null
      }

      if (!ComponentPreview.componentCssTextPromiseByPath.has(stylesheetPath)) {
        ComponentPreview.componentCssTextPromiseByPath.set(
          stylesheetPath,
          this.fetchTextAsset(stylesheetPath),
        )
      }

      return ComponentPreview.componentCssTextPromiseByPath.get(stylesheetPath) ?? null
    }

    private async loadComponentScript(): Promise<string | null> {
      if (!ComponentPreview.componentJsTextPromise) {
        ComponentPreview.componentJsTextPromise = this.fetchTextAsset(COMPONENT_SCRIPT_PATH)
      }

      return ComponentPreview.componentJsTextPromise
    }

    private async fetchTextAsset(assetPath: string): Promise<string | null> {
      try {
        const assetResponse = await fetch(assetPath, { credentials: 'same-origin' })

        if (!assetResponse.ok) {
          return null
        }

        return assetResponse.text()
      } catch {
        return null
      }
    }

    private buildPreviewDocument(
      sourceDocumentHtml: string,
      componentCssText: string | null,
      componentJsText: string | null,
    ): string {
      const headHtml = this.buildPreviewHead(componentCssText, componentJsText)
      const bodyClassAttribute = [
        'dark font-sans antialiased',
        this.contentBodyClass ?? '',
        this.isDarkPreview ? 'bg-gray-900' : 'bg-white',
      ]
        .filter(Boolean)
        .join(' ')

      return `
        <!doctype html>
        <html>
          <head>${headHtml}</head>
          <body class="${bodyClassAttribute}">
            ${sourceDocumentHtml}
          </body>
        </html>`
    }

    private buildPreviewHead(
      componentCssText: string | null,
      componentJsText: string | null,
    ): string {
      return [
        '<meta charset="UTF-8" />',
        '<meta name="viewport" content="width=device-width, initial-scale=1.0" />',
        '<meta name="color-scheme" content="light dark" />',
        this.buildComponentStylesheetTag(componentCssText),
        this.buildPreviewConfigScriptTag(),
        this.buildDirectionScriptTag(componentJsText),
      ].join('')
    }

    private buildComponentStylesheetTag(componentCssText: string | null): string {
      if (!componentCssText) {
        return ''
      }

      return `<style data-preview-component-css>${this.escapeStyleTag(componentCssText)}</style>`
    }

    private buildPreviewConfigScriptTag(): string {
      const allowedOrigin = this.escapeScriptText(globalThis.location.origin)
      const previewMessageType = this.escapeScriptText(PREVIEW_MESSAGE_TYPE)

      return (
        `<script>globalThis.__HYPERUI_PREVIEW_ORIGIN='${allowedOrigin}';globalThis.__HYPERUI_PREVIEW_MESSAGE_TYPE='${previewMessageType}';<` +
        '/script>'
      )
    }

    private buildDirectionScriptTag(componentJsText: string | null): string {
      if (!componentJsText) {
        return ''
      }

      return (
        `<script data-preview-component-js>${this.escapeScriptTag(componentJsText)}<` + '/script>'
      )
    }

    private async getContent(): Promise<string | null> {
      if (this.contentHtml) {
        return this.contentHtml
      }

      if (this.rawSourceHtml) {
        this.contentHtml = this.extractBodyContent(this.rawSourceHtml)

        return this.contentHtml
      }

      await this.loadContent()

      return this.contentHtml
    }

    private extractBodyContent(documentHtml: string): string | null {
      return documentHtml
    }

    private escapeScriptText(scriptValue: string): string {
      return scriptValue.replaceAll('\\', '\\\\').replaceAll("'", "\\'")
    }

    private escapeStyleTag(styleValue: string): string {
      return styleValue.replace(/<\/style/gi, '<\\/style')
    }

    private escapeScriptTag(scriptValue: string): string {
      return scriptValue.replace(/<\/script/gi, '<\\/script')
    }

    private postDirectionToIframe() {
      if (!this.iframeEl?.contentWindow) {
        return
      }

      try {
        // Use wildcard delivery and validate origin in the child
        this.iframeEl.contentWindow.postMessage(
          {
            type: PREVIEW_MESSAGE_TYPE,
            direction: this.previewDirection,
          },
          '*',
        )
      } catch {
        // We do nothing
      }
    }
  }

  customElements.define('component-preview', ComponentPreview)
</script>
