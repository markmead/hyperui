---
interface Props {
  src: string
  title: string
  dark?: boolean
  index?: number
  wrapper?: string
}

const { src, title, dark = false, index = 1, wrapper = '' } = Astro.props
---

<component-preview data-src={src} class="block border-t border-gray-200">
  <div class="relative">
    <iframe
      data-preview="true"
      {src}
      {title}
      class:list={[
        wrapper,
        dark ? 'bg-gray-900' : 'bg-white',
        'mx-auto w-full ring ring-gray-200 transition-[max-width] duration-300 data-[preview=false]:hidden data-[preview=true]:block',
      ]}
      style="max-width: 100%;"
      loading={index === 1 && !dark ? 'eager' : 'lazy'}></iframe>

    <div data-dark-overlay aria-hidden="true" class="pointer-events-none absolute inset-0 hidden overflow-hidden">
      <div data-dark-sweep class="absolute inset-y-0 w-[200%] -translate-x-full bg-gradient-to-r from-transparent via-white/50 to-transparent"></div>
    </div>
  </div>

  <div
    data-preview="true"
    class="prose prose-pre:m-0 prose-pre:rounded-none max-w-none data-[preview=true]:hidden"
  >
    <pre data-html></pre>
  </div>
</component-preview>

<script>
  class ComponentPreview extends HTMLElement {
    private contentHtml: string | null = null
    private contentSrc: string | null = null
    private originalSrc: string | null = null

    private iframeEl: HTMLIFrameElement | null = null
    private overlayEl: HTMLElement | null = null
    private sweepEl: HTMLElement | null = null
    private previewEl: HTMLPreElement | null = null

    private breakpointHandler: ((event: CustomEvent<{ width: string }>) => void) | null = null
    private copyHandler: (() => void) | null = null
    private darkHandler: ((event: CustomEvent<{ html: string | null; dark: boolean }>) => void) | null = null
    private directionHandler: ((event: CustomEvent<{ ltr: boolean }>) => void) | null = null
    private viewHandler: ((event: CustomEvent<{ previewing: boolean }>) => void) | null = null

    connectedCallback() {
      this.contentSrc = this.dataset.src || null

      if (!this.contentSrc) {
        return
      }

      this.iframeEl = this.querySelector('iframe')
      this.overlayEl = this.querySelector('[data-dark-overlay]')
      this.sweepEl = this.querySelector('[data-dark-sweep]')
      this.previewEl = this.querySelector('[data-html]')

      if (!this.iframeEl || !this.previewEl) {
        return
      }

      this.originalSrc = this.iframeEl.src

      this.setupEventListeners()
    }

    disconnectedCallback() {
      if (
        this.contentSrc &&
        this.breakpointHandler &&
        this.copyHandler &&
        this.darkHandler &&
        this.directionHandler &&
        this.viewHandler
      ) {
        // @ts-expect-error -- CustomEvent handler is not assignable to EventListener
        document.removeEventListener(`breakpoint:change:${this.contentSrc}`, this.breakpointHandler)
        document.removeEventListener(`preview:copy:${this.contentSrc}`, this.copyHandler)
        // @ts-expect-error -- CustomEvent handler is not assignable to EventListener
        document.removeEventListener(`preview:dark:${this.contentSrc}`, this.darkHandler)
        // @ts-expect-error -- CustomEvent handler is not assignable to EventListener
        document.removeEventListener(`preview:direction:${this.contentSrc}`, this.directionHandler)
        // @ts-expect-error -- CustomEvent handler is not assignable to EventListener
        document.removeEventListener(`preview:view:${this.contentSrc}`, this.viewHandler)

        this.breakpointHandler = null
        this.copyHandler = null
        this.darkHandler = null
        this.directionHandler = null
        this.viewHandler = null
      }
    }

    private setupEventListeners() {
      this.breakpointHandler = (breakpointEvent) => {
        const newWidth = breakpointEvent.detail.width

        if (this.iframeEl) {
          this.iframeEl.style.maxWidth = newWidth
        }
      }

      this.copyHandler = () => {
        const contentHtml = this.getContent()

        try {
          if (contentHtml) {
            navigator.clipboard.writeText(contentHtml)
          }
        } catch {
          // We do nothing
        }
      }

      this.directionHandler = (directionEvent) => {
        const isLtr = directionEvent.detail.ltr

        if (this.iframeEl?.contentDocument) {
          this.iframeEl.contentDocument.documentElement.setAttribute('dir', isLtr ? 'ltr' : 'rtl')
        }
      }

      this.darkHandler = (darkEvent) => {
        const { html: darkHtml, dark } = darkEvent.detail

        if (!this.iframeEl) return

        this.runSweep(() => {
          if (dark && darkHtml) {
            this.iframeEl!.classList.remove('bg-white')
            this.iframeEl!.classList.add('bg-gray-900')
            this.iframeEl!.srcdoc = darkHtml
          } else {
            this.iframeEl!.classList.remove('bg-gray-900')
            this.iframeEl!.classList.add('bg-white')
            this.iframeEl!.removeAttribute('srcdoc')
            this.iframeEl!.src = this.originalSrc!
          }
          // Invalidate cached body HTML so the copy button returns the correct variant.
          this.contentHtml = null
        })
      }

      this.viewHandler = (viewEvent) => {
        const isPreviewing = viewEvent.detail.previewing

        const previewEls = this.querySelectorAll('[data-preview]')

        const contentHtml = this.getContent()

        if (contentHtml && this.previewEl) {
          this.previewEl.textContent = contentHtml
        }

        previewEls.forEach((previewEl) => {
          previewEl.setAttribute('data-preview', isPreviewing ? 'true' : 'false')
        })
      }

      if (this.contentSrc) {
        // @ts-expect-error -- CustomEvent handler is not assignable to EventListener
        document.addEventListener(`breakpoint:change:${this.contentSrc}`, this.breakpointHandler)
        document.addEventListener(`preview:copy:${this.contentSrc}`, this.copyHandler)
        // @ts-expect-error -- CustomEvent handler is not assignable to EventListener
        document.addEventListener(`preview:dark:${this.contentSrc}`, this.darkHandler)
        // @ts-expect-error -- CustomEvent handler is not assignable to EventListener
        document.addEventListener(`preview:direction:${this.contentSrc}`, this.directionHandler)
        // @ts-expect-error -- CustomEvent handler is not assignable to EventListener
        document.addEventListener(`preview:view:${this.contentSrc}`, this.viewHandler)
      }
    }

    private getContent(): string | null {
      if (this.contentHtml) {
        return this.contentHtml
      }

      if (this.iframeEl?.contentDocument) {
        const docClone = this.iframeEl.contentDocument.cloneNode(true) as Document

        this.contentHtml = this.sanitizeContent(docClone.body.innerHTML)

        return this.contentHtml
      }

      return null
    }

    private sanitizeContent(contentHtml: string): string {
      return contentHtml
        .split('\n')
        .map((htmlLine) => htmlLine.replace(/^\s{4}/, ''))
        .join('\n')
        .trim()
    }

    /**
     * Shows a shimmer sweep animation over the iframe, calls `swapFn` at the
     * midpoint so the content change is hidden behind the passing highlight,
     * then hides the overlay once the sweep finishes.
     */
    private runSweep(swapFn: () => void) {
      if (!this.overlayEl || !this.sweepEl) {
        swapFn()
        return
      }

      const SWEEP_DURATION = 700
      const SWAP_DELAY = SWEEP_DURATION / 2
      // Small buffer to let the CSS animation fully complete before hiding the overlay.
      const CLEANUP_BUFFER = 50

      this.overlayEl.classList.remove('hidden')
      // Drive animation duration from the JS constant so both stay in sync.
      this.sweepEl.style.animation = `sweep ${SWEEP_DURATION}ms ease-in-out forwards`

      setTimeout(swapFn, SWAP_DELAY)

      setTimeout(() => {
        if (this.overlayEl) {
          this.overlayEl.classList.add('hidden')
        }
        if (this.sweepEl) {
          this.sweepEl.style.animation = ''
        }
      }, SWEEP_DURATION + CLEANUP_BUFFER)
    }
  }

  customElements.define('component-preview', ComponentPreview)
</script>

<style>
  @keyframes sweep {
    from {
      transform: translateX(-100%) skewX(-12deg);
    }
    to {
      transform: translateX(200%) skewX(-12deg);
    }
  }
</style>
