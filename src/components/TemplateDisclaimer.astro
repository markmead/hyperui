---
import { TriangleAlert } from '@lucide/astro'
---

<div class="mx-auto max-w-7xl px-4 pb-8">
  <div class="flex items-start gap-4 rounded-lg border border-gray-200 bg-gray-50 p-8">
    <TriangleAlert class="mt-0.5 size-6 shrink-0 text-gray-500" />

    <div>
      <h2 class="text-xl font-medium">Starting point — not a finished product</h2>

      <p class="mt-2 text-gray-600">
        This template combines existing HyperUI components into a full page layout to help you move
        faster. It still needs real content, working functionality, accessibility checks, and
        testing before it's ready for production.
      </p>
    </div>
  </div>
</div>
