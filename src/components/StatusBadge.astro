---
interface Props {
  label: string
  dotColor?: string
  class?: string
}

const { label, dotColor, class: className } = Astro.props
---

<span
  class:list={[
    'inline-flex shrink-0 items-center gap-1.5 rounded-full border border-gray-200 bg-gray-50 px-2.5 py-0.5 text-xs font-medium text-gray-600',
    className,
  ]}
>
  {dotColor && <span class={`size-1.5 rounded-full ${dotColor}`} aria-hidden="true" />}
  {label}
</span>
