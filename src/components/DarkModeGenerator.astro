---
import { Clipboard, ChevronDown, Info, Plus, X } from '@lucide/astro'
import DmgRulesExamplesDialog from './DmgRulesExamplesDialog.astro'
---

<dark-mode-generator class="block">
  <div class="flex flex-col gap-6 lg:flex-row">
    <aside class="flex shrink-0 flex-col gap-4 lg:w-72 lg:self-start xl:w-80">
      <div>
        <label for="dmg-input" class="text-sm font-medium text-gray-700"> Paste HTML </label>

        <textarea
          id="dmg-input"
          data-input
          rows="4"
          class="mt-0.5 w-full resize-none rounded-md border-gray-200 align-bottom text-sm"
        ></textarea>
      </div>

      <div
        class="flex w-full flex-col divide-y divide-gray-200 overflow-hidden rounded-lg bg-gray-50"
      >
        <div class="p-4">
          <h3 class="text-sm font-medium text-gray-700">Options</h3>

          <label class="mt-2 inline-flex items-center gap-3">
            <input type="checkbox" data-overwrite-existing class="size-5 rounded border-gray-300" />

            <span class="text-sm font-medium text-gray-700">
              Overwrite existing <code class="rounded bg-gray-200 px-1 py-0.5">dark:</code> classes
            </span>
          </label>
        </div>

        <details class="group" open>
          <summary
            class="flex cursor-pointer items-center justify-between p-4 transition-colors hover:bg-white [&::-webkit-details-marker]:hidden"
          >
            <h3 class="text-sm font-medium text-gray-700">Utilities</h3>

            <ChevronDown
              class="size-4 shrink-0 text-gray-600 transition-transform group-open:rotate-180"
            />
          </summary>

          <div class="border-t border-gray-200 p-4">
            <div data-utilities class="flex flex-wrap gap-1"></div>
          </div>
        </details>

        <details class="group" open>
          <summary
            class="flex cursor-pointer items-center justify-between p-4 transition-colors hover:bg-white [&::-webkit-details-marker]:hidden"
          >
            <h3 class="text-sm font-medium text-gray-700">Shade map</h3>
            <ChevronDown
              class="size-4 shrink-0 text-gray-600 transition-transform group-open:rotate-180"
            />
          </summary>

          <div class="border-t border-gray-200 p-4">
            <div data-shade-map class="grid grid-cols-2 gap-x-6 gap-y-3"></div>
          </div>
        </details>

        <details class="group flex-1" open>
          <summary
            class="flex cursor-pointer items-center justify-between p-4 transition-colors hover:bg-white [&::-webkit-details-marker]:hidden"
          >
            <h3 class="text-sm font-medium text-gray-700">Rules</h3>

            <div class="flex items-center gap-2">
              <button
                type="button"
                data-rules-examples
                aria-label="View rule examples"
                class="inline-flex items-center justify-center rounded-md border border-gray-200 bg-white p-1 text-gray-400 transition-colors hover:border-gray-300 hover:text-gray-600"
              >
                <Info class="size-4" />
              </button>

              <button
                type="button"
                data-add-rule
                class="inline-flex items-center justify-center gap-1 rounded-md bg-gray-900 px-3 py-1.5 text-xs font-medium text-white transition-colors hover:bg-gray-800"
              >
                <Plus class="size-4" />

                <span>Add rule</span>
              </button>

              <ChevronDown
                class="size-4 shrink-0 text-gray-600 transition-transform group-open:rotate-180"
              />
            </div>
          </summary>

          <div class="border-t border-gray-200 p-4">
            <ul data-rules class="space-y-2"></ul>
          </div>
        </details>

        <div class="flex flex-wrap gap-2 p-4">
          <button
            type="button"
            data-reset
            title="Resets the shade map, utility toggles, and rules back to their defaults"
            class="rounded-md border border-gray-200 bg-white px-3 py-1.5 text-xs text-gray-600 transition-colors hover:border-gray-300 hover:bg-gray-50"
          >
            Reset
          </button>

          <button
            type="button"
            data-export
            class="rounded-md border border-gray-200 bg-white px-3 py-1.5 text-xs text-gray-600 transition-colors hover:border-gray-300 hover:bg-gray-50"
          >
            Export
          </button>

          <label
            class="cursor-pointer rounded-md border border-gray-200 bg-white px-3 py-1.5 text-xs text-gray-600 transition-colors hover:border-gray-300 hover:bg-gray-50"
          >
            Import
            <input type="file" data-import accept=".json" class="sr-only" />
          </label>
        </div>
      </div>
    </aside>

    <div class="flex flex-1 flex-col">
      <div class="flex items-center justify-end gap-2">
        <button
          type="button"
          data-copy
          aria-label="Copy output HTML"
          aria-pressed="false"
          class="inline-flex items-center justify-center gap-2 rounded-md bg-gray-900 px-3 py-1.5 text-sm font-medium text-white transition-colors hover:bg-gray-800"
        >
          <Clipboard class="size-4" />

          <span data-copy-text>Copy</span>
        </button>

        <div class="flex items-center gap-1 rounded-md border border-gray-200 bg-white p-0.5">
          <button
            type="button"
            data-preview-mode="light"
            aria-pressed="false"
            class="rounded px-2.5 py-1 text-sm font-medium text-gray-600 transition-colors hover:bg-gray-100 aria-pressed:bg-gray-900 aria-pressed:text-white"
          >
            Light
          </button>

          <button
            type="button"
            data-preview-mode="dark"
            aria-pressed="false"
            class="rounded px-2.5 py-1 text-sm font-medium text-gray-600 transition-colors hover:bg-gray-100 aria-pressed:bg-gray-900 aria-pressed:text-white"
          >
            Dark
          </button>

          <button
            type="button"
            data-preview-mode="split"
            aria-pressed="true"
            class="rounded px-2.5 py-1 text-sm font-medium text-gray-600 transition-colors hover:bg-gray-100 aria-pressed:bg-gray-900 aria-pressed:text-white"
          >
            Split
          </button>

          <button
            type="button"
            data-preview-mode="code"
            aria-pressed="false"
            class="rounded px-2.5 py-1 text-sm font-medium text-gray-600 transition-colors hover:bg-gray-100 aria-pressed:bg-gray-900 aria-pressed:text-white"
          >
            Code
          </button>
        </div>
      </div>

      <div data-code-container class="mt-4 hidden flex-1">
        <div class="prose prose-pre:m-0 prose-pre:rounded-none max-w-none">
          <pre data-output class="h-112 overflow-auto text-sm whitespace-pre-wrap"></pre>
        </div>
      </div>

      <div data-preview-container class="mt-4 grid min-h-0 flex-1 grid-cols-2 gap-4">
        <iframe
          data-preview="light"
          title="Light mode preview"
          sandbox="allow-scripts"
          class="h-112 w-full rounded-lg bg-white ring ring-gray-200"></iframe>

        <iframe
          data-preview="dark"
          title="Dark mode preview"
          sandbox="allow-scripts"
          class="h-112 w-full rounded-lg bg-gray-900 ring ring-gray-800"></iframe>
      </div>
    </div>
  </div>

  <DmgRulesExamplesDialog />
</dark-mode-generator>

<script>
  import {
    loadConfig,
    saveConfig,
    resetConfig,
    exportConfig,
    importConfig,
  } from '../lib/dark-mode/config.js'
  import { transformHtmlDom } from '../lib/dark-mode/transform-html.js'
  import { buildPreviewDocument } from '../lib/dark-mode/preview-document.js'
  import {
    renderUtilityToggles,
    renderShadeMap,
    renderRules,
  } from '../lib/dark-mode/ui-renderer.js'
  import { DEBOUNCE_DELAY_MS } from '../lib/dark-mode/element-constants.js'

  type Rule = {
    id: string
    enabled: boolean
    utilities: string[] | null
    shade: number | null
    colors: string[] | null
    darkShade: number | null
    excludeElements: string[]
    excludeColors: string[]
  }

  type Config = {
    shadeMap: Record<number, number>
    colorMap: Record<string, string>
    utilities: Record<string, boolean>
    rules: Rule[]
    overwriteExisting: boolean
  }

  type PreviewMode = 'light' | 'dark' | 'split' | 'code'

  class DarkModeGenerator extends HTMLElement {
    private generatorConfig: Config = loadConfig() as Config
    private debounceTimer: ReturnType<typeof setTimeout> | null = null
    private clipboardCopyTimer: ReturnType<typeof setTimeout> | null = null
    private currentPreviewMode: PreviewMode = 'split'

    connectedCallback() {
      this.refreshUtilityToggles()
      this.refreshShadeMap()
      this.refreshRules()
      this.syncOverwriteExisting()
      this.bindHtmlInput()
      this.bindActionButtons()
      this.applyPreviewMode('split')
    }

    disconnectedCallback() {
      if (this.debounceTimer) {
        clearTimeout(this.debounceTimer)
      }
      if (this.clipboardCopyTimer) {
        clearTimeout(this.clipboardCopyTimer)
      }
    }

    // ── Render helpers ──────────────────────────────────────────────

    private refreshUtilityToggles() {
      const utilitiesContainer = this.querySelector<HTMLElement>('[data-utilities]')
      if (!utilitiesContainer) {
        return
      }
      renderUtilityToggles(utilitiesContainer, this.generatorConfig, () => {
        this.saveConfiguration()
        this.transformAndRender()
      })
    }

    private refreshShadeMap() {
      const shadeMapContainer = this.querySelector<HTMLElement>('[data-shade-map]')
      if (!shadeMapContainer) {
        return
      }
      renderShadeMap(shadeMapContainer, this.generatorConfig, () => {
        this.saveConfiguration()
        this.transformAndRender()
      })
    }

    private refreshRules() {
      const rulesContainer = this.querySelector<HTMLElement>('[data-rules]')
      if (!rulesContainer) {
        return
      }
      renderRules(rulesContainer, this.generatorConfig, {
        onDelete: (deletedRuleId: string) => {
          this.generatorConfig.rules = this.generatorConfig.rules.filter(
            (existingRule) => existingRule.id !== deletedRuleId,
          )
          this.refreshRules()
          this.saveConfiguration()
          this.transformAndRender()
        },
        onChange: () => {
          this.saveConfiguration()
          this.transformAndRender()
        },
      })
    }

    private syncOverwriteExisting() {
      const overwriteCheckbox = this.querySelector<HTMLInputElement>('[data-overwrite-existing]')
      if (!overwriteCheckbox) {
        return
      }

      overwriteCheckbox.checked = this.generatorConfig.overwriteExisting
      overwriteCheckbox.addEventListener('change', () => {
        this.generatorConfig.overwriteExisting = overwriteCheckbox.checked
        this.saveConfiguration()
        this.transformAndRender()
      })
    }

    // ── Binding ────────────────────────────────────────────────────

    private bindHtmlInput() {
      const htmlTextarea = this.querySelector<HTMLTextAreaElement>('[data-input]')
      if (!htmlTextarea) {
        return
      }

      htmlTextarea.addEventListener('input', () => {
        if (this.debounceTimer) {
          clearTimeout(this.debounceTimer)
        }
        this.debounceTimer = setTimeout(() => this.transformAndRender(), DEBOUNCE_DELAY_MS)
      })
    }

    private bindActionButtons() {
      const rulesDialog = this.querySelector<HTMLDialogElement>('[data-rules-dialog]')

      this.querySelector('[data-rules-examples]')?.addEventListener('click', (clickEvent) => {
        clickEvent.stopPropagation()
        rulesDialog?.showModal()
      })

      this.querySelector('[data-rules-dialog-close]')?.addEventListener('click', () => {
        rulesDialog?.close()
      })

      rulesDialog?.addEventListener('click', (clickEvent) => {
        if (clickEvent.target === rulesDialog) {
          rulesDialog.close()
        }
      })

      // stopPropagation prevents the Rules <details> from toggling closed
      this.querySelector('[data-add-rule]')?.addEventListener('click', (clickEvent) => {
        clickEvent.stopPropagation()
        const newRule: Rule = {
          id: crypto.randomUUID(),
          enabled: true,
          utilities: null,
          shade: null,
          colors: null,
          darkShade: null,
          excludeElements: [],
          excludeColors: [],
        }
        this.generatorConfig.rules.push(newRule)
        this.refreshRules()
        this.saveConfiguration()
        this.querySelector<HTMLDetailsElement>('[data-rules]')
          ?.closest('details')
          ?.setAttribute('open', '')
        const ruleDetailEls = this.querySelectorAll<HTMLDetailsElement>('[data-rules] details')
        ruleDetailEls[ruleDetailEls.length - 1]?.setAttribute('open', '')
      })

      this.querySelector('[data-reset]')?.addEventListener('click', () => {
        this.generatorConfig = resetConfig() as Config
        this.refreshUtilityToggles()
        this.refreshShadeMap()
        this.refreshRules()
        this.syncOverwriteExisting()
        this.transformAndRender()
      })

      this.querySelector('[data-export]')?.addEventListener('click', () => {
        const exportJson = exportConfig(this.generatorConfig)
        const exportBlob = new Blob([exportJson], { type: 'application/json' })
        const downloadUrl = URL.createObjectURL(exportBlob)
        const downloadLink = document.createElement('a')
        downloadLink.href = downloadUrl
        downloadLink.download = 'dark-mode-config.json'
        downloadLink.click()
        URL.revokeObjectURL(downloadUrl)
      })

      this.querySelector<HTMLInputElement>('[data-import]')?.addEventListener(
        'change',
        (changeEvent) => {
          const importedFile = (changeEvent.target as HTMLInputElement).files?.[0]
          if (!importedFile) {
            return
          }

          const fileReader = new FileReader()
          fileReader.onload = () => {
            const importResult = importConfig(String(fileReader.result))
            if (!importResult.ok) {
              alert(`Import failed: ${importResult.error}`)
              return
            }
            this.generatorConfig = importResult.config as Config
            this.refreshUtilityToggles()
            this.refreshShadeMap()
            this.refreshRules()
            this.syncOverwriteExisting()
            this.saveConfiguration()
            this.transformAndRender()
          }
          fileReader.readAsText(importedFile)
        },
      )

      const copyButton = this.querySelector<HTMLButtonElement>('[data-copy]')
      const copyButtonText = this.querySelector<HTMLElement>('[data-copy-text]')
      const copyLiveRegion = this.querySelector<HTMLElement>('[data-copy-polite]')

      copyButton?.addEventListener('click', async () => {
        const outputText = this.querySelector<HTMLPreElement>('[data-output]')?.textContent ?? ''
        if (!outputText.trim()) {
          return
        }

        try {
          await navigator.clipboard.writeText(outputText)

          if (copyButtonText) {
            copyButtonText.textContent = 'Copied'
          }
          if (copyLiveRegion) {
            copyLiveRegion.textContent = 'Copied to clipboard.'
          }
          copyButton.setAttribute('aria-pressed', 'true')

          if (this.clipboardCopyTimer) {
            clearTimeout(this.clipboardCopyTimer)
          }
          this.clipboardCopyTimer = setTimeout(() => {
            if (copyButtonText) {
              copyButtonText.textContent = 'Copy'
            }
            if (copyLiveRegion) {
              copyLiveRegion.textContent = ''
            }
            copyButton.setAttribute('aria-pressed', 'false')
          }, 1500)
        } catch {
          // clipboard write failed silently
        }
      })

      this.querySelectorAll<HTMLButtonElement>('[data-preview-mode]').forEach((modeButton) => {
        modeButton.addEventListener('click', () => {
          const previewMode = modeButton.dataset.previewMode as PreviewMode
          this.applyPreviewMode(previewMode)
          this.querySelectorAll<HTMLButtonElement>('[data-preview-mode]').forEach((otherButton) => {
            otherButton.setAttribute('aria-pressed', otherButton === modeButton ? 'true' : 'false')
          })
        })
      })
    }

    // ── Core logic ─────────────────────────────────────────────────

    private transformAndRender() {
      const inputValue = this.querySelector<HTMLTextAreaElement>('[data-input]')?.value ?? ''
      const outputElement = this.querySelector<HTMLPreElement>('[data-output]')

      if (!outputElement) {
        return
      }

      if (!inputValue.trim()) {
        outputElement.textContent = ''
        this.updatePreviewFrames('', '')
        return
      }

      const transformedHtml = transformHtmlDom(inputValue, this.generatorConfig)

      outputElement.textContent = transformedHtml

      const lightHtml = new DOMParser().parseFromString(inputValue, 'text/html').body.innerHTML
      this.updatePreviewFrames(lightHtml, transformedHtml)
    }

    private updatePreviewFrames(lightHtml: string, darkHtml: string) {
      const lightPreviewFrame = this.querySelector<HTMLIFrameElement>('[data-preview="light"]')
      const darkPreviewFrame = this.querySelector<HTMLIFrameElement>('[data-preview="dark"]')

      if (lightPreviewFrame) {
        lightPreviewFrame.srcdoc = buildPreviewDocument(lightHtml, false)
      }
      if (darkPreviewFrame) {
        darkPreviewFrame.srcdoc = buildPreviewDocument(darkHtml, true)
      }
    }

    private applyPreviewMode(previewMode: PreviewMode) {
      this.currentPreviewMode = previewMode

      const previewContainer = this.querySelector<HTMLElement>('[data-preview-container]')
      const codeContainer = this.querySelector<HTMLElement>('[data-code-container]')
      const lightPreviewFrame = this.querySelector<HTMLIFrameElement>('[data-preview="light"]')
      const darkPreviewFrame = this.querySelector<HTMLIFrameElement>('[data-preview="dark"]')

      if (!previewContainer || !codeContainer || !lightPreviewFrame || !darkPreviewFrame) {
        return
      }

      if (previewMode === 'code') {
        previewContainer.classList.add('hidden')
        codeContainer.classList.remove('hidden')
        return
      }

      previewContainer.classList.remove('hidden')
      codeContainer.classList.add('hidden')

      if (previewMode === 'light') {
        previewContainer.classList.remove('grid-cols-2')
        lightPreviewFrame.classList.remove('hidden')
        darkPreviewFrame.classList.add('hidden')
      } else if (previewMode === 'dark') {
        previewContainer.classList.remove('grid-cols-2')
        lightPreviewFrame.classList.add('hidden')
        darkPreviewFrame.classList.remove('hidden')
      } else {
        previewContainer.classList.add('grid-cols-2')
        lightPreviewFrame.classList.remove('hidden')
        darkPreviewFrame.classList.remove('hidden')
      }
    }

    private saveConfiguration() {
      saveConfig(this.generatorConfig)
    }
  }

  customElements.define('dark-mode-generator', DarkModeGenerator)
</script>

<style is:global>
  [data-rules-dialog] {
    transition:
      opacity 0.2s ease,
      transform 0.2s ease,
      display 0.2s allow-discrete,
      overlay 0.2s allow-discrete;
  }

  [data-rules-dialog][open] {
    opacity: 1;
    transform: scale(1) translateY(0);
  }

  [data-rules-dialog]:not([open]) {
    opacity: 0;
    transform: scale(0.95) translateY(-6px);
  }

  @starting-style {
    [data-rules-dialog][open] {
      opacity: 0;
      transform: scale(0.95) translateY(-6px);
    }
  }

  [data-rules-dialog]::backdrop {
    background: rgb(0 0 0 / 0);
    transition:
      background 0.2s ease,
      display 0.2s allow-discrete,
      overlay 0.2s allow-discrete;
  }

  [data-rules-dialog][open]::backdrop {
    background: rgb(0 0 0 / 0.4);
  }

  @starting-style {
    [data-rules-dialog][open]::backdrop {
      background: rgb(0 0 0 / 0);
    }
  }
</style>
