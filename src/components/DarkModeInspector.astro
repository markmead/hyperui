---
import { X } from '@lucide/astro'
---

<dialog
  data-rule-inspector
  class="fixed inset-x-0 bottom-0 top-auto z-50 m-0 w-full max-w-none rounded-t-xl border-t border-gray-200 bg-white p-0 shadow-xl open:flex open:flex-col"
>
  <div class="flex items-center justify-between border-b border-gray-200 p-4">
    <h2 class="text-sm font-medium text-gray-900" data-inspector-rule-name>Rule</h2>

    <button
      type="button"
      data-inspector-close
      aria-label="Close inspector"
      class="rounded-md p-1 text-gray-600 transition-colors hover:bg-gray-100 hover:text-gray-900"
    >
      <X class="size-5" />
    </button>
  </div>

  <div class="p-4">
    <div class="grid grid-cols-2 gap-4 sm:grid-cols-4 lg:grid-cols-7">
      <label class="block text-sm font-medium text-gray-700">
        Name
        <input
          type="text"
          data-inspector-name
          class="mt-0.5 w-full rounded-md border-gray-200 text-sm"
          placeholder="e.g. Invert text"
        />
        <span class="mt-1 block text-xs font-normal text-gray-400">Optional label for this rule.</span>
      </label>

      <label class="block text-sm font-medium text-gray-700">
        Utilities
        <input
          type="text"
          data-inspector-utilities
          class="mt-0.5 w-full rounded-md border-gray-200 text-sm"
          placeholder="e.g. bg, text"
        />
        <span class="mt-1 block text-xs font-normal text-gray-400"
          >Comma-separated. Leave blank to match any.</span
        >
      </label>

      <label class="block text-sm font-medium text-gray-700">
        Shade
        <input
          type="number"
          data-inspector-shade
          class="mt-0.5 w-full rounded-md border-gray-200 text-sm [appearance:textfield] [&::-webkit-inner-spin-button]:appearance-none [&::-webkit-outer-spin-button]:appearance-none"
          placeholder="e.g. 600"
          min="50"
          max="950"
          step="50"
        />
        <span class="mt-1 block text-xs font-normal text-gray-400">Leave blank to match any shade.</span>
      </label>

      <label class="block text-sm font-medium text-gray-700">
        Include colors
        <input
          type="text"
          data-inspector-colors
          class="mt-0.5 w-full rounded-md border-gray-200 text-sm"
          placeholder="e.g. blue, indigo"
        />
        <span class="mt-1 block text-xs font-normal text-gray-400"
          >Comma-separated. Leave blank to match any.</span
        >
      </label>

      <label class="block text-sm font-medium text-gray-700">
        Use shade
        <input
          type="number"
          data-inspector-dark-shade
          class="mt-0.5 w-full rounded-md border-gray-200 text-sm [appearance:textfield] [&::-webkit-inner-spin-button]:appearance-none [&::-webkit-outer-spin-button]:appearance-none"
          placeholder="e.g. 300"
          min="50"
          max="950"
          step="50"
        />
        <span class="mt-1 block text-xs font-normal text-gray-400">Leave blank to use the shade map.</span>
      </label>

      <label class="block text-sm font-medium text-gray-700">
        Skip elements
        <input
          type="text"
          data-inspector-exclude-elements
          class="mt-0.5 w-full rounded-md border-gray-200 text-sm"
          placeholder="e.g. button, a"
        />
        <span class="mt-1 block text-xs font-normal text-gray-400">Comma-separated.</span>
      </label>

      <label class="block text-sm font-medium text-gray-700">
        Skip colors
        <input
          type="text"
          data-inspector-exclude-colors
          class="mt-0.5 w-full rounded-md border-gray-200 text-sm"
          placeholder="e.g. blue, indigo"
        />
        <span class="mt-1 block text-xs font-normal text-gray-400">Comma-separated.</span>
      </label>
    </div>
  </div>
</dialog>
