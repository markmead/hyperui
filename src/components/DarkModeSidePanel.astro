---
import { ChevronDown, Info, Plus } from '@lucide/astro'
---

<aside class="flex shrink-0 flex-col gap-4 lg:w-72 lg:self-start xl:w-80">
  <div>
    <label for="dark-mode-input" class="text-sm font-medium text-gray-700"> Paste HTML </label>

    <textarea
      id="dark-mode-input"
      data-input
      rows="4"
      class="mt-0.5 w-full resize-none rounded-md border-gray-200 align-bottom text-sm"></textarea>
  </div>

  <div
    class="flex w-full flex-col divide-y divide-gray-200 overflow-hidden rounded-lg border border-gray-200 bg-gray-50"
  >
    <details class="group" open>
      <summary
        class="flex cursor-pointer items-center justify-between p-4 transition-colors hover:bg-white [&::-webkit-details-marker]:hidden"
      >
        <h3 class="text-sm font-medium text-gray-700">Utilities</h3>

        <ChevronDown
          class="size-4 shrink-0 text-gray-600 transition-transform group-open:rotate-180"
        />
      </summary>

      <div class="border-t border-gray-200 p-4">
        <div data-utilities class="flex flex-wrap gap-1"></div>
      </div>
    </details>

    <details class="group">
      <summary
        class="flex cursor-pointer items-center justify-between p-4 transition-colors hover:bg-white [&::-webkit-details-marker]:hidden"
      >
        <h3 class="text-sm font-medium text-gray-700">Shade map</h3>

        <ChevronDown
          class="size-4 shrink-0 text-gray-600 transition-transform group-open:rotate-180"
        />
      </summary>

      <div class="border-t border-gray-200 p-4">
        <div data-shade-map class="grid grid-cols-2 gap-x-6 gap-y-3"></div>
      </div>
    </details>

    <details class="group flex-1">
      <summary
        class="flex cursor-pointer items-center justify-between p-4 transition-colors hover:bg-white [&::-webkit-details-marker]:hidden"
      >
        <h3 class="text-sm font-medium text-gray-700">
          Rules <span data-rules-count class="font-normal text-gray-600"></span>
        </h3>

        <div class="flex items-center gap-2">
          <button
            type="button"
            data-rules-examples
            aria-label="View rule examples"
            class="inline-flex items-center justify-center rounded-md border border-gray-200 bg-white p-1 text-gray-600 transition-colors hover:bg-gray-50 hover:text-gray-900"
          >
            <Info class="size-4" />
          </button>

          <button
            type="button"
            data-add-rule
            class="inline-flex items-center justify-center gap-1 rounded-md bg-gray-900 px-3 py-1.5 text-xs font-medium text-white transition-colors hover:bg-gray-800"
          >
            <Plus class="size-4" />

            <span>Add rule</span>
          </button>

          <ChevronDown
            class="size-4 shrink-0 text-gray-600 transition-transform group-open:rotate-180"
          />
        </div>
      </summary>

      <div class="border-t border-gray-200 p-4">
        <ul data-rules class="space-y-2"></ul>
      </div>
    </details>
  </div>

  <div class="flex items-center justify-between gap-4">
    <p data-last-saved class="text-xs text-gray-600"></p>

    <div class="inline-flex items-center gap-1 rounded-md border border-gray-200 bg-white p-0.5">
      <button
        type="button"
        data-reset
        title="Resets the shade map, utility toggles, and rules back to their defaults"
        class="rounded px-2.5 py-1 text-sm font-medium text-gray-600 transition-colors hover:bg-gray-100"
      >
        Reset
      </button>

      <button
        type="button"
        data-export
        class="rounded px-2.5 py-1 text-sm font-medium text-gray-600 transition-colors hover:bg-gray-100"
      >
        Export
      </button>

      <label
        class="cursor-pointer rounded px-2.5 py-1 text-sm font-medium text-gray-600 transition-colors hover:bg-gray-100"
      >
        Import
        <input type="file" data-import accept=".json" class="sr-only" />
      </label>
    </div>
  </div>
</aside>
